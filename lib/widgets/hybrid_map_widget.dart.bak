import 'dart:async';
import 'package:flutter/material.dart';
import 'package:flutter/foundation.dart';
import 'package:flutter/gestures.dart';
import 'package:mapbox_maps_flutter/mapbox_maps_flutter.dart';
import 'package:geolocator/geolocator.dart' as geo;
import 'package:g_route_app/theme/app_theme.dart';
import 'package:g_route_app/services/poi_service.dart';

class HybridMapWidget extends StatefulWidget {
  final bool isFullScreen;
  const HybridMapWidget({super.key, this.isFullScreen = false});

  @override
  State<HybridMapWidget> createState() => _HybridMapWidgetState();
}

class _HybridMapWidgetState extends State<HybridMapWidget> {
  MapboxMap? _mapboxMap;
  PointAnnotationManager? _annotationManager;
  Timer? _searchDebounce;
  Point? _lastSearchPosition;
  bool _isLoadingPois = false;
  List<Map<String, dynamic>> _pois = [];

  // Toggle States
  bool _showRoteiro = true;
  bool _showFluxo = false;
  bool _showRisco = false;

  @override
  void dispose() {
    _searchDebounce?.cancel();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return Column(
      children: [
        Expanded(
          flex: widget.isFullScreen ? 1 : 0,
          child: Container(
            width: double.infinity,
            height: widget.isFullScreen ? null : 450,
            decoration: const BoxDecoration(
              color: Color(0xFFF8F9FE),
            ),
            child: Stack(
              children: [
                RepaintBoundary(
                  child: MapWidget(
                    key: const ValueKey("mapbox_map"),
                    cameraOptions: CameraOptions(
                      center: Point(coordinates: Position(-46.6559, -23.5615)),
                      zoom: 15.0,
                    ),
                    onMapCreated: _onMapCreated,
                    onCameraChangeListener: _onCameraChanged,
                    gestureRecognizers: {
                      Factory<OneSequenceGestureRecognizer>(() => EagerGestureRecognizer()),
                    },
                  ),
                ),
                
                // Barra de carregamento sutil e moderna
                if (_isLoadingPois)
                  Positioned(
                    top: widget.isFullScreen ? 0 : 0,
                    left: 0,
                    right: 0,
                    child: LinearProgressIndicator(
                      backgroundColor: Colors.transparent,
                      valueColor: AlwaysStoppedAnimation<Color>(AppTheme.primaryPurple.withOpacity(0.5)),
                      minHeight: 3,
                    ),
                  ),

                // Botões Flutuantes Superiores (Zoom e GPS)
                Positioned(
                  top: widget.isFullScreen ? 50 : 15,
                  right: 15,
                  child: Column(
                    children: [
                      _buildMapActionBtn(Icons.my_location, _resetCamera),
                      const SizedBox(height: 8),
                      _buildMapActionBtn(Icons.add, () => _zoom(true)),
                      const SizedBox(height: 8),
                      _buildMapActionBtn(Icons.remove, () => _zoom(false)),
                    ],
                  ),
                ),

                // Botões de Toggle Flutuantes Inferiores (Só no modo FullScreen)
                if (widget.isFullScreen)
                  Positioned(
                    bottom: 130,
                    left: 20,
                    right: 20,
                    child: Row(
                      children: [
                        Expanded(child: _buildToggleBtn("Roteiro", Icons.route_outlined, _showRoteiro, () => setState(() => _showRoteiro = !_showRoteiro))),
                        const SizedBox(width: 8),
                        Expanded(child: _buildToggleBtn("Fluxo", Icons.people_outline, _showFluxo, () => setState(() => _showFluxo = !_showFluxo))),
                        const SizedBox(width: 8),
                        Expanded(child: _buildToggleBtn("Risco", Icons.warning_amber_rounded, _showRisco, () => setState(() => _showRisco = !_showRisco))),
                      ],
                    ),
                  ),
              ],
            ),
          ),
        ),
        
        // Se NÃO for full screen, mostra os botões embaixo como antes (compatibilidade)
        if (!widget.isFullScreen) ...[
          const SizedBox(height: 20),
          Padding(
            padding: const EdgeInsets.symmetric(horizontal: 20),
            child: Row(
              children: [
                Expanded(child: _buildToggleBtn("Roteiro", Icons.route_outlined, _showRoteiro, () => setState(() => _showRoteiro = !_showRoteiro))),
                const SizedBox(width: 8),
                Expanded(child: _buildToggleBtn("Fluxo", Icons.people_outline, _showFluxo, () => setState(() => _showFluxo = !_showFluxo))),
                const SizedBox(width: 8),
                Expanded(child: _buildToggleBtn("Risco", Icons.warning_amber_rounded, _showRisco, () => setState(() => _showRisco = !_showRisco))),
              ],
            ),
          ),
        ],
      ],
    );
  }

  void _onMapCreated(MapboxMap mapboxMap) {
    _mapboxMap = mapboxMap;
    _mapboxMap?.loadStyleURI(MapboxStyles.MAPBOX_STREETS);
    
    // Inicializa o Gerenciador de Anotações uma única vez (Performance Fix)
    _mapboxMap?.annotations.createPointAnnotationManager().then((manager) {
      _annotationManager = manager;
    });

    // Esconde os ornamentos conforme solicitado
    _mapboxMap?.scaleBar.updateSettings(ScaleBarSettings(enabled: false));
    _mapboxMap?.logo.updateSettings(LogoSettings(enabled: false));
    _mapboxMap?.attribution.updateSettings(AttributionSettings(enabled: false));
    
    _refreshPois();
  }

  void _onCameraChanged(CameraChangedEventData event) {
    _searchDebounce?.cancel();
    _searchDebounce = Timer(const Duration(milliseconds: 1000), () {
      if (mounted) _refreshPois();
    });
  }

  Future<void> _refreshPois() async {
    if (_mapboxMap == null) return;
    
    try {
      final cameraState = await _mapboxMap!.getCameraState();
      final Point center = cameraState.center;
      final lat = center.coordinates.lat.toDouble();
      final lng = center.coordinates.lng.toDouble();
      
      // Verificação Inteligente de Distância (Performance Fix)
      if (_lastSearchPosition != null) {
        final distance = geo.Geolocator.distanceBetween(
          _lastSearchPosition!.coordinates.lat.toDouble(),
          _lastSearchPosition!.coordinates.lng.toDouble(),
          lat,
          lng,
        );
        
        // Se o usuário moveu menos de 500 metros, não precisa recarregar
        if (distance < 500) {
          print("POI Service: Pulando busca, movimento menor que 500m ($distance m)");
          return;
        }
      }

      setState(() => _isLoadingPois = true);
      
      // Raio reduzido para 1000m para maior relevância e velocidade
      final pois = await PoiService.fetchPois(lat, lng, radius: 1000);

      if (mounted) {
        setState(() {
          _pois = pois;
          _isLoadingPois = false;
          _lastSearchPosition = center; // Atualiza a última posição de busca
          _updatePoiMarkers();
        });
      }
    } catch (e) {
      print("Erro ao buscar POIs: $e");
      if (mounted) setState(() => _isLoadingPois = false);
    }
  }

  void _updatePoiMarkers() {
    if (_annotationManager == null) return;
    
    _annotationManager!.deleteAll();
    
    final List<PointAnnotationOptions> options = _pois.map((poi) {
      return PointAnnotationOptions(
        geometry: Point(coordinates: Position(poi['lng'], poi['lat'])),
        textField: poi['name'],
        textColor: Colors.black.value,
        textSize: 10.0,
        textOffset: [0.0, 1.5],
        iconImage: "marker-15",
      );
    }).toList();

    _annotationManager!.createMulti(options);
  }

  void _resetCamera() {
    _mapboxMap?.setCamera(CameraOptions(
      center: Point(coordinates: Position(-46.6559, -23.5615)),
      zoom: 15.0,
      bearing: 0,
      pitch: 0,
    ));
    _refreshPois();
  }

  void _zoom(bool zoomIn) async {
    final currentZoom = await _mapboxMap?.getCameraState().then((s) => s.zoom);
    if (currentZoom != null) {
      _mapboxMap?.setCamera(CameraOptions(zoom: currentZoom + (zoomIn ? 1 : -1)));
    }
  }

  Widget _buildToggleBtn(String label, IconData icon, bool isActive, VoidCallback onTap) {
    return GestureDetector(
      onTap: onTap,
      child: AnimatedContainer(
        duration: const Duration(milliseconds: 200),
        padding: const EdgeInsets.symmetric(vertical: 12),
        decoration: BoxDecoration(
          color: isActive ? AppTheme.primaryPurple : Colors.white.withOpacity(0.9),
          borderRadius: BorderRadius.circular(15),
          border: Border.all(color: isActive ? AppTheme.primaryPurple : Colors.white),
          boxShadow: [
            BoxShadow(
              color: Colors.black.withOpacity(0.1),
              blurRadius: 8,
              offset: const Offset(0, 4),
            )
          ],
        ),
        child: Column(
          children: [
            Icon(icon, color: isActive ? Colors.white : AppTheme.textGrey, size: 18),
            const SizedBox(height: 4),
            Text(label, style: TextStyle(color: isActive ? Colors.white : AppTheme.textGrey, fontSize: 10, fontWeight: FontWeight.bold)),
          ],
        ),
      ),
    );
  }

  Widget _buildMapActionBtn(IconData icon, VoidCallback onTap) {
    return Material(
      color: Colors.white.withOpacity(0.9),
      shape: const CircleBorder(),
      elevation: 4,
      child: InkWell(
        onTap: onTap,
        customBorder: const CircleBorder(),
        child: Container(
          padding: const EdgeInsets.all(8),
          child: Icon(icon, color: AppTheme.textDark, size: 20),
        ),
      ),
    );
  }
}
